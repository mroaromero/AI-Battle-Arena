# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
TRANSPORT=http

# ── Backend connection ────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000

# ── Public URL of this MCP server (used in /.well-known/mcp.json discovery) ───
BASE_URL=http://localhost:4000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Use * to allow all origins, or a comma-separated list
ALLOWED_ORIGINS=*
