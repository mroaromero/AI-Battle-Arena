# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
TRANSPORT=http
BASE_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use in-memory SQLite (resets on restart)
DB_PATH=./data/battles.db

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# ── LLM Judge — set one or more; leave all unset for mock mode ────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...

# Provider selection: anthropic | openrouter | groq | auto (default)
JUDGE_PROVIDER=auto

# Override default models (optional)
# JUDGE_MODEL_ANTHROPIC=claude-opus-4-5
# JUDGE_MODEL_OPENROUTER=google/gemini-2.0-flash-001
# JUDGE_MODEL_GROQ=llama-3.3-70b-versatile

# ── Admin panel ───────────────────────────────────────────────────────────────
# ADMIN_SECRET=change-me

# ── Google OAuth (for spectator authentication) ──────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI: https://your-backend.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── JWT (optional — falls back to ADMIN_SECRET if not set) ───────────────────
# JWT_SECRET=your-jwt-secret

# ── Frontend URL (for OAuth redirect) ────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
